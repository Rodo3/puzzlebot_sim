<?xml version="1.0"?>
<robot name="Puzzlebot_Jetson_Lidar_Ed.">

  <!--MATERIALS-->
  <material name="yellow">
    <color rgba="0.8 0.7 0.1 1.0"/>
  </material>

  <!--LINKS-->

  <!-- Base footprint (massless reference) -->
  <link name="base_footprint"/>

  <!-- Base link -->
  <link name="base_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Jetson_Lidar_Edition_Base.stl"/>
      </geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry><box size="0.20 0.15 0.10"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0116" ixy="0" ixz="0"
                            iyy="0.0108" iyz="0"
                                         izz="0.0196"/>
    </inertial>
  </link>

  <!-- Right wheel -->
  <link name="wheel_r_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Wheel.stl"/>
      </geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0 0"/>
      <geometry><cylinder length="0.03" radius="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000125" ixy="0" ixz="0"
                              iyy="0.000125" iyz="0"
                                             izz="0.00025"/>
    </inertial>
  </link>

  <!-- Left wheel -->
  <link name="wheel_l_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0 3.14159"/>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Wheel.stl"/>
      </geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0 3.14159"/>
      <geometry><cylinder length="0.03" radius="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000125" ixy="0" ixz="0"
                              iyy="0.000125" iyz="0"
                                             izz="0.00025"/>
    </inertial>
  </link>

  <!-- LiDAR link -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder length="0.04" radius="0.04"/></geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder length="0.04" radius="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000033" ixy="0" ixz="0"
                              iyy="0.000033" iyz="0"
                                             izz="0.00008"/>
    </inertial>
  </link>

  <!-- Caster (frictionless sphere) -->
  <link name="caster_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://puzzlebot_description/meshes/Puzzlebot_Caster_Wheel.stl"/>
      </geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry><sphere radius="0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000008" ixy="0" ixz="0"
                              iyy="0.000008" iyz="0"
                                             izz="0.000008"/>
    </inertial>
  </link>

  <!--JOINTS-->

  <!-- base_footprint -> base_link -->
  <joint name="base_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- base_link -> wheel_r_link -->
  <joint name="wheel_r_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_r_link"/>
    <origin xyz="0.052 -0.095 -0.0025" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- base_link -> wheel_l_link -->
  <joint name="wheel_l_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_l_link"/>
    <origin xyz="0.052 0.095 -0.0025" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- base_link -> lidar_link -->
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.0 0.0 0.15" rpy="0 0 0"/>
  </joint>

  <!-- base_link -> caster_link -->
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="-0.095 0.0 -0.03" rpy="0 0 0"/>
  </joint>

  <!--GAZEBO-->

  <gazebo reference="base_link">
    <material>Gazebo/Yellow</material>
  </gazebo>

  <gazebo reference="wheel_r_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="wheel_l_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="caster_link">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <material>Gazebo/Grey</material>
  </gazebo>

  <!-- Differential drive — subscribes to /cmd_vel, publishes wheel TFs -->
  <gazebo>
    <plugin name="differential_drive_controller"
            filename="libgazebo_ros_diff_drive.so">
      <update_rate>20</update_rate>
      <left_joint>wheel_l_joint</left_joint>
      <right_joint>wheel_r_joint</right_joint>
      <wheel_separation>0.19</wheel_separation>
      <wheel_diameter>0.10</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <publish_odom>false</publish_odom>
      <publish_odom_tf>false</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>

  <!-- LiDAR — publishes /scan (LaserScan) -->
  <gazebo reference="lidar_link">
    <sensor type="ray" name="lidar">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_lidar" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Camera — publishes /cam_img (Image) and /cam_info (CameraInfo) -->
  <gazebo reference="base_link">
    <sensor type="camera" name="camera">
      <pose>0.10 0.0 0.10 0 0 0</pose>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip><near>0.02</near><far>300</far></clip>
      </camera>
      <plugin name="gazebo_ros_camera" filename="libgazebo_ros_camera.so">
        <ros>
          <remapping>image_raw:=cam_img</remapping>
          <remapping>camera_info:=cam_info</remapping>
        </ros>
        <camera_name>camera</camera_name>
        <frame_name>base_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>
